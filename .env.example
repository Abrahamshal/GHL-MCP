# ---- Single sub-account mode (leave blank if using Agency mode below) ----
# HighLevel private integration token (PIT) for ONE sub-account.
GHL_API_KEY=your_private_integration_api_key_here

# HighLevel sub-account Location ID for that PIT.
GHL_LOCATION_ID=your_location_id_here

# ---- Agency (Company) OAuth mode — one credential, choose any sub-account ----
# When these three are set, the server runs in AGENCY mode: it exposes
# ghl_list_subaccounts / ghl_select_subaccount / ghl_current_subaccount, and all
# other tools operate in whichever sub-account you select. GHL_API_KEY and
# GHL_LOCATION_ID above become optional. Obtain these by creating a HighLevel
# Marketplace app with an "Agency" distribution, installing it on your agency, and
# capturing the client id/secret + the Company refresh token from the OAuth install.
GHL_AGENCY_CLIENT_ID=
GHL_AGENCY_CLIENT_SECRET=
GHL_AGENCY_REFRESH_TOKEN=

# Optional: agency Company ID. Auto-derived from the token if omitted.
GHL_COMPANY_ID=

# Optional: sub-account selected by default before the user picks one.
GHL_DEFAULT_LOCATION_ID=

# Optional: where the rotating agency refresh token is persisted. On Railway,
# point this at a mounted volume path (e.g. /data/ghl-token.json) so it survives
# redeploys; otherwise a redeploy requires re-pasting GHL_AGENCY_REFRESH_TOKEN.
GHL_TOKEN_STORE_PATH=

# Optional: HighLevel API base URL.
GHL_BASE_URL=https://services.leadconnectorhq.com

# Optional: HighLevel API Version header, not the project year.
# Do not change this to 2026 unless HighLevel publishes a new required API version.
GHL_API_VERSION=2023-02-21

# Optional: default HTTP/SSE server port. On Railway, PORT is injected
# automatically and takes precedence over this.
MCP_SERVER_PORT=8000
NODE_ENV=development

# Tool profile exposed over MCP: curated | stable | official | raw | full.
# For a remote connector, prefer "curated" (agent-safe workflow tools with
# write-confirmation queues) or "stable". Default is "full" (all ~859 tools).
GHL_TOOL_PROFILE=curated

# ---- Remote OAuth (required to secure /mcp as a public custom connector) ----
# When MCP_OAUTH_PASSWORD is set, the /mcp endpoint requires an OAuth 2.1 bearer
# token. Clients (e.g. Claude custom connectors) run discovery -> dynamic client
# registration -> authorization-code + PKCE. The password below is what you type
# on the consent screen to approve a connection. Use a long, random value.
# If MCP_OAUTH_PASSWORD is left unset, /mcp is UNAUTHENTICATED (local dev only).
MCP_OAUTH_PASSWORD=

# Public HTTPS origin of this server, used as the OAuth issuer / resource id.
# On Railway this is derived automatically from RAILWAY_PUBLIC_DOMAIN, so you can
# usually leave this blank. Set it explicitly if you use a custom domain, e.g.
# PUBLIC_URL=https://ghl-mcp.up.railway.app
PUBLIC_URL=

# Optional: only needed for future AI-assisted features.
OPENAI_API_KEY=your_openai_key_here_optional
